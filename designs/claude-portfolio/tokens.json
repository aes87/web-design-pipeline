{
  "color": {
    "$description": "Color tokens",
    "background": {
      "base": { "$type": "color", "$value": "oklch(0.13 0.015 270)" },
      "surface": { "$type": "color", "$value": "oklch(0.17 0.012 270)" },
      "elevated": { "$type": "color", "$value": "oklch(0.21 0.01 270)" }
    },
    "foreground": {
      "base": { "$type": "color", "$value": "oklch(0.93 0.01 90)" },
      "muted": { "$type": "color", "$value": "oklch(0.60 0.02 270)" },
      "subtle": { "$type": "color", "$value": "oklch(0.42 0.015 270)" }
    },
    "accent": {
      "primary": { "$type": "color", "$value": "oklch(0.78 0.14 55)" },
      "secondary": { "$type": "color", "$value": "oklch(0.72 0.12 165)" },
      "glow": { "$type": "color", "$value": "oklch(0.78 0.14 55 / 0.15)" }
    }
  },
  "typography": {
    "$description": "Typography tokens",
    "heading": { "$type": "fontFamily", "$value": "'Playfair Display', Georgia, serif" },
    "body": { "$type": "fontFamily", "$value": "'Inter', system-ui, sans-serif" },
    "mono": { "$type": "fontFamily", "$value": "'JetBrains Mono', monospace" }
  },
  "motion": {
    "$description": "Motion tokens",
    "easing": {
      "dramatic": { "$type": "cubicBezier", "$value": [0.16, 1, 0.3, 1] },
      "entrance": { "$type": "cubicBezier", "$value": [0.25, 0.46, 0.45, 0.94] },
      "standard": { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1] }
    },
    "duration": {
      "micro": { "$type": "duration", "$value": { "value": 200, "unit": "ms" } },
      "entrance": { "$type": "duration", "$value": { "value": 700, "unit": "ms" } },
      "hero": { "$type": "duration", "$value": { "value": 1200, "unit": "ms" } },
      "stagger": { "$type": "duration", "$value": { "value": 70, "unit": "ms" } }
    }
  }
}
